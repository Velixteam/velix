{
  "name": "@flexireact/core",
  "version": "4.1.0",
  "description": "The Modern React Framework v4 - React 19, SSR, SSG, Islands, Edge Runtime, 50+ UI Components, TypeScript, Tailwind v4",
  "main": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "type": "module",
  "bin": {
    "flexireact": "./dist/cli/index.js",
    "flexi": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./client": "./dist/core/client/index.js",
    "./server": "./dist/core/server/index.js",
    "./render": "./dist/core/render/index.js",
    "./config": "./dist/core/config.js",
    "./types": "./dist/core/types.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "npx tsx cli/index.ts dev",
    "build": "npx tsx cli/index.ts build",
    "start": "npx tsx cli/index.ts start",
    "build:package": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "react",
    "framework",
    "typescript",
    "tailwind",
    "ssr",
    "ssg",
    "rsc",
    "islands",
    "file-based-routing",
    "nextjs-alternative",
    "modern"
  ],
  "author": "FlexiReact Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flexireact/flexireact.git"
  },
  "bugs": {
    "url": "https://github.com/flexireact/flexireact/issues"
  },
  "homepage": "https://github.com/flexireact/flexireact#readme",
  "dependencies": {
    "esbuild": "0.25.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "tsx": "^4.21.0",
    "chokidar": "^3.6.0",
    "zod": "^3.24.1",
    "lru-cache": "^11.0.2"
  },
  "peerDependencies": {
    "react": ">=19.0.1",
    "react-dom": ">=19.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "eslint": "^9.18.0",
    "@eslint/js": "^9.18.0",
    "prettier": "^3.4.2",
    "eslint-config-prettier": "^9.1.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}