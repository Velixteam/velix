{
  "name": "velix",
  "version": "5.0.0",
  "private": true,
  "description": "Velix v5 — A modern full-stack React framework optimized for performance, SEO, and developer experience",
  "type": "module",
  "scripts": {
    "dev": "npx tsx packages/velix/runtime/start-dev.ts",
    "build": "npx tsx packages/velix/runtime/start-build.ts",
    "build:packages": "pnpm -r run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "loc": "node scripts/loc.js"
  },
  "keywords": [
    "react",
    "framework",
    "typescript",
    "ssr",
    "ssg",
    "islands",
    "file-based-routing",
    "fullstack",
    "seo",
    "modern"
  ],
  "author": "Velix Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Velixteam/velix.git"
  },
  "bugs": {
    "url": "https://github.com/Velixteam/velix/issues"
  },
  "homepage": "https://velixjs.dev",
  "dependencies": {
    "esbuild": "0.25.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "tsx": "^4.21.0",
    "chokidar": "^3.6.0",
    "zod": "^3.24.1",
    "lru-cache": "^11.0.2"
  },
  "peerDependencies": {
    "react": ">=19.0.1",
    "react-dom": ">=19.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "eslint": "^9.18.0",
    "@eslint/js": "^9.18.0",
    "prettier": "^3.4.2",
    "eslint-config-prettier": "^9.1.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}