  "author": "velixteam",
  "publisher": "velixteam",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=19.0.1",
    "react-dom": ">=19.0.1"
  },
  "dependencies": {
    "esbuild": "0.25.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1",
    "lru-cache": "^11.0.2",
    "chokidar": "^3.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
