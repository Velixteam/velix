{
  "name": "@velix/cache-redis",
  "version": "0.1.0",
  "description": "Redis cache adapter for Velix — implements ICacheAdapter via ioredis",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "velix",
    "cache",
    "redis",
    "ioredis"
  ],
  "author": "velixteam",
  "license": "MIT",
  "peerDependencies": {
    "ioredis": ">=5.0.0"
  },
  "devDependencies": {
    "ioredis": "^5.11.1",
    "ioredis-mock": "^8.9.0",
    "tsup": "^8.3.6",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
